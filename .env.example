# ─── Azure Service Principal ───────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ─── Azure Key Vault ───────────────────────────────────────────────────────────
AZURE_KEYVAULT_URL=

# KV secret names that hold SAS tokens (created by Terraform)
KV_SECRET_DB_SAS=storage-db-sas-token
KV_SECRET_EXPORTS_SAS=storage-exports-sas-token

# ─── Azure Storage ─────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_URL=
AZURE_DB_CONTAINER_NAME=optimizer-db
AZURE_EXPORTS_CONTAINER_NAME=optimizer-exports

# ─── Local Paths (used inside container) ───────────────────────────────────────
LOCAL_DB_PATH=/tmp/optimizer.db
DB_BLOB_NAME=optimizer.db
LOCAL_SCRIPTS_DIR=/tmp/deletion_scripts

# ─── Database Provider ─────────────────────────────────────────────────────────
# Supported values: sqlite | postgresql | mysql | sqlserver
# sqlite      – default, no extra driver, DB file synced to blob storage
# postgresql  – requires: uv pip install psycopg2-binary
# mysql       – requires: uv pip install pymysql
# sqlserver   – requires: uv pip install pyodbc + ODBC Driver 18 installed
DATABASE_PROVIDER=sqlite

# Shared connection settings (used by postgresql / mysql / sqlserver)
DB_HOST=localhost
DB_PORT=5432          # 3306 for MySQL, 1433 for SQL Server
DB_NAME=cost_optimizer
DB_USER=
DB_PASSWORD=

# PostgreSQL
DB_SSL_MODE=require

# MySQL
DB_CHARSET=utf8mb4

# SQL Server
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERT=no

# Connection pool (postgresql / mysql / sqlserver)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ─── Analysis Thresholds (configurable, not secrets) ───────────────────────────
IDLE_VM_CPU_THRESHOLD_PCT=5.0
IDLE_STORAGE_DAYS=30
IDLE_APP_DAYS=30
IDLE_DB_DAYS=30
IDLE_AKS_CPU_THRESHOLD_PCT=10.0
ANALYSIS_LOOKBACK_DAYS=30
